# Application
PROJECT_NAME=Insurance Annual Report Fact Extraction API
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
STORAGE_ROOT=data/uploads

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/insurance_facts

# Parsing / OCR
OCR_ENABLED=true
OCR_LANGUAGE=chi_sim+eng
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
TESSDATA_PREFIX=D:/Codex/insurance-fact-extraction-backend/data/tessdata
PDF_RENDER_SCALE=2.0
OCR_MIN_TEXT_LEN=20
PARSE_PAGE_RETRIES=1

# Celery (set ALWAYS_EAGER=false in real async env with Redis worker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_STORE_EAGER_RESULT=true
CELERY_TASK_TRACK_STARTED=true

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
